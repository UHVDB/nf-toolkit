/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run UHVDB/toolkit -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test create profile'
    config_profile_description = 'Minimal test dataset to check database creation function'

    // Input data
    input                   = 'https://github.com/UHVDB/toolkit2/raw/refs/heads/master/assets/test_datasets/samplesheet/test_create.csv'

    // Update options
    run_update              = true
    dtr_sequences_file      = "https://github.com/UHVDB/toolkit/raw/refs/heads/main/assets/test_datasets/tsvs/uhgv_dtrs_test.txt"

}
