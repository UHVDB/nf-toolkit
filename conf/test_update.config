/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run UHVDB/toolkit -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test update profile'
    config_profile_description = 'Minimal test dataset to check database update functionality'

    // Input data
    input                   = '/mmfs1/gscratch/pedslabs_hoffman/carsonjm/CFPhageome/repos/UHVDB/toolkit2/assets/test_datasets/samplesheet/test_update.csv'

    // Update options
    run_update              = true
    dtr_sequences_file      = "https://github.com/UHVDB/nf-toolkit/raw/refs/heads/master/assets/test_datasets/txt/uhgv_dtr_test.txt"
    local_split_size        = 100
    url_split_size          = 2
    min_checkv_update       = 2
}
